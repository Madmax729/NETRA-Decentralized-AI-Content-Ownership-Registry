# Copy this file to .env and fill in your values.
# DO NOT commit your actual .env file — it contains secrets!

# ── Frontend (Vite) ──────────────────────────────────────
# Deployed smart contract addresses (from Hardhat/Remix deploy)
VITE_CONTRACT_ADDRESS=0xYourNetworkContractAddressHere
VITE_MARKETPLACE_ADDRESS=0xYourMarketplaceContractAddressHere

# Pinata IPFS JWT (get from https://app.pinata.cloud/keys)
VITE_PINATA_JWT=your_pinata_jwt_here
