# ============================================================
# Environment Variables — NEVER commit secrets!
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Frontend (Vite / Node.js)
# ============================================================
node_modules/
dist/
dist-ssr/
*.local

# Build cache
.vite/

# Package manager lock files (keep one, ignore the rest)
# bun.lockb  ← keep if using Bun
# package-lock.json ← keep if using npm
# yarn.lock  ← keep if using Yarn

# ============================================================
# Python Server (server/)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# ============================================================
# Logs
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# OS-specific files
# ============================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# Editor / IDE files
# ============================================================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ============================================================
# Hardhat / Solidity artifacts
# ============================================================
artifacts/
cache/
typechain/
typechain-types/

# ============================================================
# Misc
# ============================================================
*.tsbuildinfo
coverage/
